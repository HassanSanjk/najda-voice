# Telnyx (phone number provider)
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=
# For browser-based WebRTC test calls (Mission Control: API Keys -> Telephony Credentials)
TELNYX_TELEPHONY_CREDENTIAL_ID=

# Deepgram
DEEPGRAM_API_KEY=
# Optional: bias Arabic STT to the caller's dialect (ar-EG, ar-SA, ar-JO, ...).
# Default "ar" is pan-Arab/MSA.
STT_LANGUAGE_AR=ar

# Groq
GROQ_API_KEY=

# Arabic TTS provider: "groq" (default — Orpheus on Groq, reuses GROQ_API_KEY,
# nothing else to configure) or "elevenlabs".
TTS_PROVIDER_AR=groq
# Orpheus Arabic voice: abdullah, fahad, sultan (male); lulwa, noura, aisha (female).
# Listen first: python scripts/test_arabic_tts.py
GROQ_TTS_VOICE_AR=aisha
# TTS request concurrency: 1 on Groq free tier, ~3 on Developer tier
GROQ_TTS_CONCURRENCY=1

# ElevenLabs (only used when TTS_PROVIDER_AR=elevenlabs).
# NOTE: free-tier ElevenLabs API keys cannot use *library* voices (402) — use a
# premade voice or a paid plan.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_AR=

# App
APP_ENV=development
PUBLIC_BASE_URL=  # e.g. https://yourname.duckdns.org
